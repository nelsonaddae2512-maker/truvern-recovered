model AssessmentRun {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organizationId Int
  organization   Organization @relation("OrgAssessmentRuns", fields: [organizationId], references: [id], onDelete: Cascade)

  vendorId Int?
  vendor   Vendor? @relation("VendorAssessmentRuns", fields: [vendorId], references: [id], onDelete: SetNull)

  assessmentId Int?
  assessment   Assessment? @relation("AssessmentRuns", fields: [assessmentId], references: [id], onDelete: SetNull)

  status      String    @default("IN_PROGRESS")
  startedAt   DateTime?
  completedAt DateTime?

  @@index([organizationId, id])
  @@index([organizationId, vendorId])
  @@index([organizationId, assessmentId])
  @@index([status])
}

model GovernanceReleaseManifest {
  id Int @id @default(autoincrement())

  organizationId     Int
  vendorId           Int?
  assessmentRunId    Int?
  reviewAssignmentId Int?
  reviewResponseId   Int?

  manifestVersion   String  @default("GRM-1.0")
  governanceVersion String?

  releaseState    String
  checksum        String
  packetChecksum  String?
  fundingChecksum String?

  reviewerName String?

  releasedAt  DateTime?
  confirmedAt DateTime?
  finalizedAt DateTime?

  immutableSnapshot Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([vendorId])
  @@index([reviewAssignmentId])
}

model OrganizationPlanOverride {
  id              Int       @id @default(autoincrement())
  organizationId  Int
  planTier        String
  reason          String?
  createdByUserId String?
  startsAt        DateTime  @default(now())
  expiresAt       DateTime?
  revokedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([planTier])
  @@index([startsAt])
  @@index([expiresAt])
  @@index([revokedAt])
}

enum NotificationType {
  ASSESSMENT_ASSIGNED_INTERNAL
  ASSESSMENT_ASSIGNED_TRUVERN
  REVIEW_COMPLETED
  ISSUE_ASSIGNED
  ISSUE_ESCALATED
  EVIDENCE_REQUEST_OVERDUE
  PROGRAM_STATE_SEALED
  REVIEW_STARTED
  REVIEW_RELEASED
  ASSESSMENT_SUBMITTED
  EVIDENCE_REQUEST_ASSIGNED
  VENDOR_ASSESSMENT_RECEIVED
  BOARD_PACKET_SEALED
  TRUST_NETWORK_PUBLISHED
  REVIEW_RELEASE_REQUESTED
  REVIEW_RELEASE_APPROVED
  REVIEW_RELEASE_DENIED
  VENDOR_SUBMITTED
  REVIEW_ASSIGNED
  TRUVERN_RELEASE_READY
  TRUVERN_RELEASED
  RELEASE_CONFIRMATION_REQUIRED
  REASSESSMENT_DUE
  REASSESSMENT_OVERDUE
  LOW_CREDITS
  CREDITS_GRANTED
  PLAN_OVERRIDE_APPLIED
  PLAN_OVERRIDE_EXPIRING
  GOVERNANCE_SEAL_VERIFIED
}

enum NotificationSeverity {
  INFO
  SUCCESS
  WARNING
  CRITICAL
}

model Notification {
  id             Int                  @id @default(autoincrement())
  userId         String?
  organizationId Int?
  type           NotificationType
  severity       NotificationSeverity @default(INFO)
  title          String
  message        String?
  href           String?
  metadataJson   Json?
  readAt         DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([userId])
  @@index([organizationId])
  @@index([type])
  @@index([severity])
  @@index([readAt])
  @@index([createdAt])
}

enum TruvernFrameworkStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum TruvernControlRequirementLevel {
  LOW
  MODERATE
  HIGH
  BASELINE
  CUSTOM
}

enum TruvernAssessmentLifecycleStatus {
  DRAFT
  SENT_TO_VENDOR
  VENDOR_IN_PROGRESS
  SUBMITTED
  IN_REVIEW
  REMEDIATION_REQUESTED
  ATTESTATION_REQUESTED
  READY_FOR_RELEASE
  RELEASED
  CANCELLED
}

enum TruvernFindingSeverity {
  INFO
  LOW
  MODERATE
  HIGH
  CRITICAL
}

enum TruvernFindingStatus {
  OPEN
  REMEDIATION_REQUESTED
  REMEDIATED
  ACCEPTED_RISK
  FALSE_POSITIVE
  CLOSED
}

enum TruvernRemediationStatus {
  REQUESTED
  IN_PROGRESS
  SUBMITTED
  ACCEPTED
  REJECTED
  WAIVED
}

enum TruvernAttestationStatus {
  REQUESTED
  SUBMITTED
  ACCEPTED
  REJECTED
  EXPIRED
}

model TruvernFramework {
  id          Int                    @id @default(autoincrement())
  slug        String                 @unique
  name        String
  description String?                @db.Text
  version     String?
  status      TruvernFrameworkStatus @default(DRAFT)
  metadata    Json?
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  controls    TruvernControl[]
  assessments TruvernFrameworkAssessment[]

  @@index([status])
  @@index([slug])
}

model TruvernControl {
  id               Int                             @id @default(autoincrement())
  frameworkId      Int
  controlId        String
  family           String?
  title            String
  description      String?                         @db.Text
  discussion       String?                         @db.Text
  guidance         String?                         @db.Text
  requirementLevel TruvernControlRequirementLevel?
  baselineLow      Boolean                         @default(false)
  baselineModerate Boolean                         @default(false)
  baselineHigh     Boolean                         @default(false)
  sortOrder        Int                             @default(0)
  metadata         Json?
  createdAt        DateTime                        @default(now())
  updatedAt        DateTime                        @updatedAt

  framework TruvernFramework           @relation(fields: [frameworkId], references: [id], onDelete: Cascade)
  questions TruvernControlQuestion[]
  findings  TruvernAssessmentFinding[]

  @@unique([frameworkId, controlId])
  @@index([frameworkId])
  @@index([family])
  @@index([controlId])
}

model TruvernControlQuestion {
  id                  Int      @id @default(autoincrement())
  controlId           Int
  prompt              String   @db.Text
  helpText            String?  @db.Text
  evidencePrompt      String?  @db.Text
  weight              Int      @default(1)
  requiresEvidence    Boolean  @default(false)
  requiresAttestation Boolean  @default(false)
  sortOrder           Int      @default(0)
  metadata            Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  control   TruvernControl              @relation(fields: [controlId], references: [id], onDelete: Cascade)
  responses TruvernAssessmentResponse[]

  @@index([controlId])
}

model TruvernFrameworkAssessment {
  id                 Int                              @id @default(autoincrement())
  frameworkId        Int
  organizationId     Int?
  vendorId           Int?
  assessmentRunId    Int?
  reviewAssignmentId Int?
  title              String
  status             TruvernAssessmentLifecycleStatus @default(DRAFT)
  score              Int?
  maxScore           Int?
  riskLevel          String?
  sentAt             DateTime?
  submittedAt        DateTime?
  remediationDueAt   DateTime?
  readyForReleaseAt  DateTime?
  releasedAt         DateTime?
  metadata           Json?
  createdAt          DateTime                         @default(now())
  updatedAt          DateTime                         @updatedAt

  framework    TruvernFramework               @relation(fields: [frameworkId], references: [id], onDelete: Restrict)
  responses    TruvernAssessmentResponse[]
  findings     TruvernAssessmentFinding[]
  attestations TruvernAssessmentAttestation[]

  @@index([frameworkId])
  @@index([organizationId])
  @@index([vendorId])
  @@index([assessmentRunId])
  @@index([reviewAssignmentId])
  @@index([status])
}

model TruvernAssessmentResponse {
  id            Int      @id @default(autoincrement())
  assessmentId  Int
  questionId    Int
  answer        Json?
  score         Int?
  reviewerNotes String?  @db.Text
  vendorNotes   String?  @db.Text
  evidence      Json?
  metadata      Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  assessment TruvernFrameworkAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  question   TruvernControlQuestion     @relation(fields: [questionId], references: [id], onDelete: Restrict)

  @@unique([assessmentId, questionId])
  @@index([assessmentId])
  @@index([questionId])
}

model TruvernAssessmentFinding {
  id                  Int                    @id @default(autoincrement())
  assessmentId        Int
  controlId           Int?
  severity            TruvernFindingSeverity
  status              TruvernFindingStatus   @default(OPEN)
  title               String
  description         String                 @db.Text
  recommendation      String?                @db.Text
  evidenceSummary     String?                @db.Text
  remediationRequired Boolean                @default(false)
  attestationRequired Boolean                @default(false)
  dueAt               DateTime?
  metadata            Json?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  assessment   TruvernFrameworkAssessment  @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  control      TruvernControl?             @relation(fields: [controlId], references: [id], onDelete: SetNull)
  remediations TruvernRemediationRequest[]

  @@index([assessmentId])
  @@index([controlId])
  @@index([severity])
  @@index([status])
}

model TruvernRemediationRequest {
  id               Int                      @id @default(autoincrement())
  findingId        Int
  status           TruvernRemediationStatus @default(REQUESTED)
  requestText      String                   @db.Text
  vendorResponse   String?                  @db.Text
  reviewerDecision String?                  @db.Text
  dueAt            DateTime?
  submittedAt      DateTime?
  resolvedAt       DateTime?
  metadata         Json?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt

  finding TruvernAssessmentFinding @relation(fields: [findingId], references: [id], onDelete: Cascade)

  @@index([findingId])
  @@index([status])
}

model TruvernAssessmentAttestation {
  id           Int                      @id @default(autoincrement())
  assessmentId Int
  title        String
  description  String?                  @db.Text
  requestedBy  String?
  submittedBy  String?
  status       TruvernAttestationStatus @default(REQUESTED)
  evidence     Json?
  expiresAt    DateTime?
  submittedAt  DateTime?
  reviewedAt   DateTime?
  metadata     Json?
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt

  assessment TruvernFrameworkAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@index([assessmentId])
  @@index([status])
}
