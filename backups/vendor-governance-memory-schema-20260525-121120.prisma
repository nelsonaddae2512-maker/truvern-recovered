generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/**
 * -------------------------------------------------------
 * ENUMS
 * -------------------------------------------------------
 */

enum OrgRole {
  OWNER
  ADMIN
  ANALYST
  VIEWER
  VENDOR // external/vendor user
}

enum PlanTier {
  FREE
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  INACTIVE
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
}

enum VendorTier {
  CRITICAL
  IMPORTANT
  STANDARD
}

enum VendorCriticality {
  HIGH
  MEDIUM
  LOW
}

enum AssessmentStatus {
  DRAFT
  LAUNCHED
  IN_PROGRESS
  SUBMITTED
  REVIEW_READY
  UNDER_REVIEW
  RELEASED
  COMPLETED
  ARCHIVED
}

enum IssueSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IssueStatus {
  OPEN
  IN_REVIEW
  RESOLVED
  ACCEPTED_RISK
}

enum EvidenceKind {
  POLICY
  REPORT
  SCREENSHOT
  CERTIFICATE
  OTHER
}

