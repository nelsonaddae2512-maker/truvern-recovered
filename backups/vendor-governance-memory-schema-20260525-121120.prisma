 */

model Issue {
  id             Int     @id @default(autoincrement())
  organizationId Int
  vendorId       Int
  assessmentId   Int?
  title          String
  description    String?

  severity IssueSeverity @default(MEDIUM)
  status   IssueStatus   @default(OPEN)

  openedAt  DateTime @default(now())
  createdAt DateTime @default(now())

  dueAt     DateTime?
  updatedAt DateTime  @default(now()) @updatedAt

  closedAt     DateTime?
  createdById  Int?
  assignedToId Int?
  organization Organization @relation(fields: [organizationId], references: [id])
  vendor       Vendor       @relation(fields: [vendorId], references: [id])
  assessment   Assessment?  @relation(fields: [assessmentId], references: [id])
  createdBy    User?        @relation("IssueCreatedBy", fields: [createdById], references: [id])
  assignedTo   User?        @relation("IssueAssignedTo", fields: [assignedToId], references: [id])

  events IssueEvent[]

  @@index([organizationId, vendorId])
  @@index([status, severity])
  @@index([dueAt])
}

/**
 * -------------------------------------------------------
 * BILLING & USAGE (Stripe-friendly)
 * -------------------------------------------------------
 */

model BillingPlan {
  id            Int      @id @default(autoincrement())
  tier          PlanTier @unique
  name          String
  description   String?
  stripePriceId String?  @unique
  maxVendors    Int?
  maxMembers    Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  subscriptions Subscription[]
}

model VendorRiskSnapshot {
  id       Int      @id @default(autoincrement())
  vendor   Vendor   @relation(fields: [vendorId], references: [id])
  vendorId Int
  score    Int?
  takenAt  DateTime @default(now())

  @@index([vendorId, takenAt])
}

model VendorPortalUser {
  id             Int    @id @default(autoincrement())
  organizationId Int
  vendorId       Int
  clerkUserId    String @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  vendor       Vendor       @relation(fields: [vendorId], references: [id])

  @@index([organizationId])
  @@index([vendorId])
}

model Subscription {
  id               Int                @id @default(autoincrement())
  organizationId   Int
  planId           Int
  status           SubscriptionStatus @default(INACTIVE)
  stripeCustomerId String?            @unique
  stripeSubId      String?            @unique
  currentPeriodEnd DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  plan         BillingPlan  @relation(fields: [planId], references: [id])
}

model UsageEvent {
  id             Int      @id @default(autoincrement())
  organizationId Int
  vendorId       Int?
  kind           String
  details        Json?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  vendor       Vendor?      @relation(fields: [vendorId], references: [id])

  @@index([organizationId, kind, createdAt])
}

/**
 * -------------------------------------------------------
 * INVITES
 * -------------------------------------------------------
 */

model InviteToken {
  id             Int       @id @default(autoincrement())
  organizationId Int
  email          String
  role           OrgRole
  token          String    @unique
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, email])
}

