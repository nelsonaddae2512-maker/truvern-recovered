 */
model VendorContact {
  id        Int               @id @default(autoincrement())
  vendorId  Int
  name      String?
  email     String
  phone     String?
  role      VendorContactRole @default(OTHER)
  isPrimary Boolean           @default(false)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@unique([vendorId, email]) // prevent duplicate emails per vendor
  @@index([vendorId])
  @@index([vendorId, isPrimary])
}

model VendorRiskAlert {
  id         Int       @id @default(autoincrement())
  vendor     Vendor    @relation(fields: [vendorId], references: [id])
  vendorId   Int
  type       String
  message    String
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?

  @@index([vendorId, type, resolvedAt])
}

model GovernanceTransparencyLog {
  id Int @id @default(autoincrement())

  entryId String @unique

  assignmentId Int
  responseId   Int

  checksum   String
  ledgerHash String

  receiptId String

  timestamp DateTime

  previousEntryHash String?
  entryHash         String

  createdAt DateTime @default(now())

  @@index([assignmentId])
  @@index([responseId])
  @@index([entryHash])
  @@index([timestamp])
}

model TrustProfile {
  id             Int      @id @default(autoincrement())
  vendorId       Int      @unique
  organizationId Int
  isPublic       Boolean  @default(false)
  publicSlug     String?  @unique
  headline       String?
  summary        String?
  updatedAt      DateTime @updatedAt
  createdAt      DateTime @default(now())

  vendor       Vendor       @relation(fields: [vendorId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])
  links        TrustLink[]
}

model VendorShareToken {
  id        Int       @id @default(autoincrement())
  vendorId  Int
  token     String    @unique
  expiresAt DateTime?
  createdAt DateTime  @default(now())

  vendor Vendor @relation(fields: [vendorId], references: [id])

  @@index([vendorId])
  @@index([expiresAt])
}

model TrustLink {
  id             Int       @id @default(autoincrement())
  trustProfileId Int
  token          String    @unique
  label          String?
  expiresAt      DateTime?
  createdAt      DateTime  @default(now())

  trustProfile TrustProfile @relation(fields: [trustProfileId], references: [id])
}

