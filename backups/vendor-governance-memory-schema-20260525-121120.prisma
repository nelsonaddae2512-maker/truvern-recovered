model ActivityEvent {
  id Int @id @default(autoincrement())

  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  actorUserId String? // Clerk user id (null = system)
  actorName   String?
  actorEmail  String?

  vendorId Int?
  vendor   Vendor? @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  type        String // e.g. VENDOR_CREATED, EVIDENCE_ADDED
  title       String
  description String?

  metadata Json?

  createdAt DateTime @default(now())

  @@index([organizationId, createdAt])
  @@index([vendorId, createdAt])
  @@index([type, createdAt])
}

/**
 * -------------------------------------------------------
 * VENDORS & TRUST NETWORK
 * -------------------------------------------------------
 */

model Vendor {
  lastAssessmentCompletedAt DateTime?
  nextReviewDueAt           DateTime?
  reviewCadenceDays         Int?
  id                        Int                @id @default(autoincrement())
  organizationId            Int
  name                      String
  slug                      String             @unique
  category                  String?
  tier                      VendorTier?
  criticality               VendorCriticality?
  riskScore                 Int?
  status                    String?
  summary                   String?            @db.Text

  // Legacy single-contact fields (kept for backward compatibility)
