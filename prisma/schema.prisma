  RemediationPackage RemediationPackage @relation(fields: [packageId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  RemediationTask    RemediationTask?   @relation(fields: [taskId], references: [id], onUpdate: NoAction)
  WorkflowInstance   WorkflowInstance?  @relation(fields: [workflowId], references: [id], onUpdate: NoAction)
}

model RemediationAttachment {
  id                 Int                 @id @default(autoincrement())
  packageId          Int
  taskId             Int?
  messageId          Int?
  workflowId         Int?
  evidenceId         Int?
  reviewAssignmentId Int
  vendorId           Int
  organizationId     Int
  filename           String
  fileUrl            String?
  storageKey         String?
  contentType        String?
  sizeBytes          Int?
  status             String              @default("UPLOADED")
  reviewStatus       String              @default("PENDING_REVIEW")
  reviewComment      String?
  uploadedBy         String?
  uploadedAt         DateTime            @default(now()) @db.Timestamp(6)
  reviewedAt         DateTime?           @db.Timestamp(6)
  createdAt          DateTime            @default(now()) @db.Timestamp(6)
  updatedAt          DateTime            @default(now()) @db.Timestamp(6)
  RemediationMessage RemediationMessage? @relation(fields: [messageId], references: [id], onUpdate: NoAction)
  RemediationPackage RemediationPackage  @relation(fields: [packageId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  RemediationTask    RemediationTask?    @relation(fields: [taskId], references: [id], onUpdate: NoAction)
  WorkflowInstance   WorkflowInstance?   @relation(fields: [workflowId], references: [id], onUpdate: NoAction)

  @@index([packageId, reviewStatus, uploadedAt], map: "idx_remediation_attachment_package")
}

model RemediationMessage {
  id                    Int                     @id @default(autoincrement())
  packageId             Int
  taskId                Int?
  workflowId            Int?
  reviewAssignmentId    Int
  vendorId              Int
  organizationId        Int
  authorType            String                  @default("SYSTEM")
  authorId              String?
  authorName            String?
  message               String
  visibility            String                  @default("VENDOR_AND_TRUVERN")
  createdAt             DateTime                @default(now()) @db.Timestamp(6)
