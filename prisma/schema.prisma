generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/**
 * -------------------------------------------------------
 * ENUMS
 * -------------------------------------------------------
 */

enum OrgRole {
  OWNER
  ADMIN
  ANALYST
  VIEWER
  VENDOR // external/vendor user
}

enum PlanTier {
  FREE
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  INACTIVE
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
}

enum VendorTier {
  CRITICAL
  IMPORTANT
  STANDARD
}

enum VendorCriticality {
  HIGH
  MEDIUM
  LOW
}

enum AssessmentStatus {
  DRAFT
  LAUNCHED
  IN_PROGRESS
  SUBMITTED
  REVIEW_READY
  UNDER_REVIEW
  RELEASED
  COMPLETED
  ARCHIVED
}

enum IssueSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IssueStatus {
  OPEN
  IN_REVIEW
  RESOLVED
  ACCEPTED_RISK
}

enum EvidenceKind {
  POLICY
  REPORT
  SCREENSHOT
  CERTIFICATE
  OTHER
}

/**
 * -------------------------------------------------------
 * EVIDENCE REQUESTS
 * -------------------------------------------------------
 */

enum EvidenceRequestStatus {
  OPEN
  SUBMITTED
  APPROVED
  REJECTED
  CANCELLED
  REQUESTED
}

enum EvidenceRequestKind {
  SOC2
  ISO27001
  POLICY
  PEN_TEST
  BCP_DRP
  DPIA
  OTHER
}

enum AssessmentQuestionType {
  TEXT // Freeform text response
  YES_NO // Yes / No
  SELECT // Single choice from a set
  MULTI_SELECT // Multiple choices
  NUMBER // Numeric input (for counts, days, etc.)
}

// Existing/legacy question type enum (kept for compatibility)
// EXTENDED to support new UI-friendly values.
enum QuestionType {
  BOOLEAN
  TEXT
  MULTI_CHOICE
  YES_NO
  NUMBER
  MULTIPLE_CHOICE
  FILE_UPLOAD
}

/**
 */
enum VendorContactRole {
  PRIMARY
  SECURITY
  COMPLIANCE
  LEGAL
  OTHER
}

/**
 * -------------------------------------------------------
 * CORE MULTI-TENANT MODELS
 * -------------------------------------------------------
 */

model Organization {
  planOverrides OrganizationPlanOverride[]
  clerkOrgId    String?                    @unique
  id            Int                        @id @default(autoincrement())
  name          String
  slug          String                     @unique
  createdAt     DateTime                   @default(now())
  updatedAt     DateTime                   @updatedAt

  // Relationships
  memberships         OrgMembership[]
  users               User[]               @relation("OrgUsers")
  vendors             Vendor[]
  assessments         Assessment[]
  evidence            Evidence[]
  issues              Issue[]
  assessmentTemplates AssessmentTemplate[]
  trustProfiles       TrustProfile[]
  subscriptions       Subscription[]
  usageEvents         UsageEvent[]
  invites             InviteToken[]

  assessmentRuns AssessmentRun[] @relation("OrgAssessmentRuns")

  evidenceRequests EvidenceRequest[]

  activityEvents    ActivityEvent[]
  vendorPortalUsers VendorPortalUser[]

  planTier String? @default("FREE")

  @@unique([name])
}

model ReviewAssignment {
  id              Int    @id @default(autoincrement())
  organizationId  Int
  vendorId        Int
  reviewRequestId Int?
  assignmentType  String
  status          String

  reviewerUserId       String?
  assignedReviewerName String?
  reviewerName         String?
  assignedTo           String?

  note        String?
  createdBy   String?
  startedAt   DateTime?
  claimedAt   DateTime?
  submittedAt DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([organizationId])
  @@index([vendorId])
  @@index([reviewRequestId])
  @@index([reviewerUserId])
  @@index([assignmentType])
  @@index([status])
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  clerkId   String?  @unique

  // Primary organization (optional, for quick linking)
  organization   Organization? @relation("OrgUsers", fields: [organizationId], references: [id])
  organizationId Int?

  memberships      OrgMembership[]
  uploadedEvidence Evidence[]
  createdIssues    Issue[]         @relation("IssueCreatedBy")
  assignedIssues   Issue[]         @relation("IssueAssignedTo")
}

model OrgMembership {
  id             Int      @id @default(autoincrement())
  userId         Int
  organizationId Int
  role           OrgRole
  createdAt      DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([userId, organizationId])
}

/**
 * -------------------------------------------------------
 * -------------------------------------------------------
 */

/**
 * -------------------------------------------------------
 * GLOBAL ACTIVITY FEED
 * -------------------------------------------------------
 */

model ActivityEvent {
  id Int @id @default(autoincrement())

  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  actorUserId String? // Clerk user id (null = system)
  actorName   String?
  actorEmail  String?

  vendorId Int?
  vendor   Vendor? @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  type        String // e.g. VENDOR_CREATED, EVIDENCE_ADDED
  title       String
  description String?

  metadata Json?

  createdAt DateTime @default(now())

  @@index([organizationId, createdAt])
  @@index([vendorId, createdAt])
  @@index([type, createdAt])
}

/**
 * -------------------------------------------------------
 * VENDORS & TRUST NETWORK
 * -------------------------------------------------------
 */

/**
 * -------------------------------------------------------
 * VENDORS & TRUST NETWORK
 * -------------------------------------------------------
 */

model Vendor {
  governanceMemories        VendorGovernanceMemory[]
  lastAssessmentCompletedAt DateTime?
  nextReviewDueAt           DateTime?
  reviewCadenceDays         Int?
  id                        Int                      @id @default(autoincrement())
  organizationId            Int
  name                      String
  slug                      String                   @unique
  category                  String?
  tier                      VendorTier?
  criticality               VendorCriticality?
  riskScore                 Int?
  status                    String?
  summary                   String?                  @db.Text

  // Legacy single-contact fields (kept for backward compatibility)
  contactName  String?
  contactEmail String?

  contacts VendorContact[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  organization Organization       @relation(fields: [organizationId], references: [id])
  assessments  Assessment[]
  evidence     Evidence[]
  issues       Issue[]
  trustProfile TrustProfile?
  usageEvents  UsageEvent[]
  shareTokens  VendorShareToken[]

  assessmentRuns AssessmentRun[] @relation("VendorAssessmentRuns")

  evidenceRequests EvidenceRequest[]

  activityEvents ActivityEvent[]

  // Trend summary flags
  riskTrend30d  String?
  riskTrend90d  String?
  riskSnapshots VendorRiskSnapshot[]
  riskAlerts    VendorRiskAlert[]
  portalUsers   VendorPortalUser[]

  @@unique([organizationId, name])
}

/**
 */
/**
 * -------------------------------------------------------
 * VENDOR CONTACTS
 * -------------------------------------------------------
 */

model VendorContact {
  id        Int               @id @default(autoincrement())
  vendorId  Int
  name      String?
  email     String
  phone     String?
  role      VendorContactRole @default(OTHER)
  isPrimary Boolean           @default(false)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@unique([vendorId, email]) // prevent duplicate emails per vendor
  @@index([vendorId])
  @@index([vendorId, isPrimary])
}

model VendorRiskAlert {
  id         Int       @id @default(autoincrement())
  vendor     Vendor    @relation(fields: [vendorId], references: [id])
  vendorId   Int
  type       String
  message    String
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?

  @@index([vendorId, type, resolvedAt])
}

model GovernanceTransparencyLog {
  id Int @id @default(autoincrement())

  entryId String @unique

  assignmentId Int
  responseId   Int

  checksum   String
  ledgerHash String

  receiptId String

  timestamp DateTime

  previousEntryHash String?
  entryHash         String

  createdAt DateTime @default(now())

  eventKey           String?
  eventType          String?
  eventHash          String?
  payloadHash        String?
  actorUserId        String?
  organizationId     Int?
  reviewAssignmentId Int?
  reviewRequestId    Int?
  vendorId           Int?
  metadataJson       Json     @default("{}")
  updatedAt          DateTime @default(now()) @db.Timestamp(6)

  @@index([assignmentId])
  @@index([responseId])
  @@index([entryHash])
  @@index([timestamp])
}

model TrustProfile {
  id             Int      @id @default(autoincrement())
  vendorId       Int      @unique
  organizationId Int
  isPublic       Boolean  @default(false)
  publicSlug     String?  @unique
  headline       String?
  summary        String?
  updatedAt      DateTime @updatedAt
  createdAt      DateTime @default(now())

  vendor       Vendor       @relation(fields: [vendorId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])
  links        TrustLink[]
}

model VendorShareToken {
  id        Int       @id @default(autoincrement())
  vendorId  Int
  token     String    @unique
  expiresAt DateTime?
  createdAt DateTime  @default(now())

  vendor Vendor @relation(fields: [vendorId], references: [id])

  @@index([vendorId])
  @@index([expiresAt])
}

model TrustLink {
  id             Int       @id @default(autoincrement())
  trustProfileId Int
  token          String    @unique
  label          String?
  expiresAt      DateTime?
  createdAt      DateTime  @default(now())

  trustProfile TrustProfile @relation(fields: [trustProfileId], references: [id])
}

/**
 * -------------------------------------------------------
 * -------------------------------------------------------
 */

model EvidenceRequest {
  id             Int                   @id @default(autoincrement())
  vendorId       Int
  organizationId Int
  requestedBy    String
  kind           EvidenceRequestKind   @default(OTHER)
  label          String
  description    String?
  dueAt          DateTime?
  status         EvidenceRequestStatus @default(OPEN)

  // Legacy: optional link to a single Evidence item (kept for backward compatibility)
  evidenceId Int?

  // Legacy direct relation (kept)
  evidence Evidence[]

  iterations EvidenceRequestIteration[]

  // lifecycle timestamps (request-level)
  submittedAt DateTime?
  reviewedAt  DateTime?
  reviewNote  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vendor       Vendor       @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  assessmentRunId     Int?
  title               String?
  category            String?
  requestedAt         DateTime? @db.Timestamp(6)
  completedAt         DateTime? @db.Timestamp(6)
  notes               String?
  reviewerNotes       String?
  vendorResponse      String?
  resolutionNotes     String?
  completedBy         String?
  assignedTo          String?
  attachmentCount     Int?      @default(0)
  evidenceCount       Int?      @default(0)
  fulfilledEvidenceId Int?
  fulfilledAt         DateTime? @db.Timestamp(6)

  @@index([vendorId, status])
  @@index([organizationId])
}

model EvidenceRequestIteration {
  id                Int                   @id @default(autoincrement())
  evidenceRequestId Int
  status            EvidenceRequestStatus @default(SUBMITTED)

  submittedBy String?
  submittedAt DateTime? @default(now())

  reviewedAt   DateTime?
  reviewerNote String?

  createdAt DateTime @default(now())

  evidenceRequest EvidenceRequest @relation(fields: [evidenceRequestId], references: [id], onDelete: Cascade)
  files           Evidence[]

  @@index([evidenceRequestId, submittedAt])
}

/**
 * -------------------------------------------------------
 * ASSESSMENTS, QUESTIONS & ANSWERS
 * -------------------------------------------------------
 */

enum TemplateAccessTier {
  FREE
  PRO
  ENTERPRISE
}

enum TemplateSource {
  SYSTEM
  CUSTOM
}

model AssessmentTemplate {
  id             Int     @id @default(autoincrement())
  organizationId Int?
  name           String
  description    String?
  standard       String?

  code     String? @unique
  category String?
  version  String?
  isActive Boolean @default(true)

  source     TemplateSource      @default(CUSTOM)
  accessTier TemplateAccessTier?
  isSystem   Boolean             @default(false)
  isFeatured Boolean             @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization?        @relation(fields: [organizationId], references: [id])
  sections     AssessmentSection[]
  questions    AssessmentQuestion[]
  assessments  Assessment[]

  catalogKey String?
  origin     String? @default("CUSTOM")
}

model AssessmentSection {
  id          Int     @id @default(autoincrement())
  templateId  Int
  title       String
  description String?
  order       Int     @default(0)
  weight      Float?

  template  AssessmentTemplate   @relation(fields: [templateId], references: [id], onDelete: Cascade)
  questions AssessmentQuestion[]
}

model AssessmentQuestion {
  id Int @id @default(autoincrement())

  templateId Int?
  sectionId  Int?
  orderIndex Int
  text       String

  helpText    String?
  description String?
  category    String?

  type     QuestionType
  richType AssessmentQuestionType?

  required Boolean @default(false)
  weight   Int?

  key     String?
  options Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  template AssessmentTemplate? @relation(fields: [templateId], references: [id])
  section  AssessmentSection?  @relation(fields: [sectionId], references: [id])
  answers  AssessmentAnswer[]
}

model Assessment {
  id             Int              @id @default(autoincrement())
  organizationId Int
  vendorId       Int
  templateId     Int?
  status         AssessmentStatus @default(DRAFT)
  token          String?          @unique

  vendorEmail       String?
  vendorContactName String?

  launchedAt    DateTime?
  openedAt      DateTime?
  reviewReadyAt DateTime?

  submissionVersion Int @default(1)

  internalReviewerId String?
  truvernReviewerId  String?

  reviewAssignmentId Int?

  completionPercent Int @default(0)

  isVendorSubmitted Boolean @default(false)

  title String?
  dueAt DateTime?

  startedAt   DateTime?
  submittedAt DateTime?
  completedAt DateTime?
  reopenedAt  DateTime?
  archivedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  score                Int?
  confidentialityScore Int?
  integrityScore       Int?
  availabilityScore    Int?
  organization         Organization        @relation(fields: [organizationId], references: [id])
  vendor               Vendor              @relation(fields: [vendorId], references: [id])
  template             AssessmentTemplate? @relation(fields: [templateId], references: [id])
  answers              AssessmentAnswer[]

  runs AssessmentRun[] @relation("AssessmentRuns")

  issues   Issue[]
  evidence Evidence[]
}

model IssueEvent {
  id        Int      @id @default(autoincrement())
  issueId   Int
  type      String
  payload   Json?
  createdAt DateTime @default(now())

  issue Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)

  @@index([issueId, createdAt])
}

model AssessmentAnswer {
  id           Int @id @default(autoincrement())
  assessmentId Int
  questionId   Int

  value      String? @db.Text
  valueJson  Json?
  riskImpact Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assessment Assessment         @relation(fields: [assessmentId], references: [id])
  question   AssessmentQuestion @relation(fields: [questionId], references: [id])

  @@unique([assessmentId, questionId])
}

/**
 * -------------------------------------------------------
 * EVIDENCE
 * -------------------------------------------------------
 */

model Evidence {
  id Int @id @default(autoincrement())

  vendorId       Int
  organizationId Int
  assessmentId   Int?
  uploadedById   Int?

  evidenceRequestId Int?
  iterationId       Int?

  title       String
  description String?
  fileUrl     String?
  kind        EvidenceKind @default(OTHER)
  uploadedAt  DateTime     @default(now())
  deletedAt   DateTime?

  vendor       Vendor       @relation(fields: [vendorId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])
  assessment   Assessment?  @relation(fields: [assessmentId], references: [id])
  uploadedBy   User?        @relation(fields: [uploadedById], references: [id])

  evidenceRequest EvidenceRequest?          @relation(fields: [evidenceRequestId], references: [id], onDelete: SetNull)
  iteration       EvidenceRequestIteration? @relation(fields: [iterationId], references: [id], onDelete: SetNull)

  notes        String?
  url          String?
  createdAt    DateTime? @db.Timestamp(6)
  updatedAt    DateTime? @db.Timestamp(6)
  documentDate DateTime? @db.Timestamp(6)
  validUntil   DateTime? @db.Timestamp(6)

  @@index([evidenceRequestId])
  @@index([iterationId])
}

/**
 * -------------------------------------------------------
 * ISSUES / FINDINGS
 * -------------------------------------------------------
 */

model Issue {
  id             Int     @id @default(autoincrement())
  organizationId Int
  vendorId       Int
  assessmentId   Int?
  title          String
  description    String?

  severity IssueSeverity @default(MEDIUM)
  status   IssueStatus   @default(OPEN)

  openedAt  DateTime @default(now())
  createdAt DateTime @default(now())

  dueAt     DateTime?
  updatedAt DateTime  @default(now()) @updatedAt

  closedAt     DateTime?
  createdById  Int?
  assignedToId Int?
  organization Organization @relation(fields: [organizationId], references: [id])
  vendor       Vendor       @relation(fields: [vendorId], references: [id])
  assessment   Assessment?  @relation(fields: [assessmentId], references: [id])
  createdBy    User?        @relation("IssueCreatedBy", fields: [createdById], references: [id])
  assignedTo   User?        @relation("IssueAssignedTo", fields: [assignedToId], references: [id])

  events IssueEvent[]

  @@index([organizationId, vendorId])
  @@index([status, severity])
  @@index([dueAt])
}

/**
 * -------------------------------------------------------
 * BILLING & USAGE (Stripe-friendly)
 * -------------------------------------------------------
 */

model BillingPlan {
  id            Int      @id @default(autoincrement())
  tier          PlanTier @unique
  name          String
  description   String?
  stripePriceId String?  @unique
  maxVendors    Int?
  maxMembers    Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  subscriptions Subscription[]
}

model VendorRiskSnapshot {
  id       Int      @id @default(autoincrement())
  vendor   Vendor   @relation(fields: [vendorId], references: [id])
  vendorId Int
  score    Int?
  takenAt  DateTime @default(now())

  @@index([vendorId, takenAt])
}

model VendorPortalUser {
  id             Int    @id @default(autoincrement())
  organizationId Int
  vendorId       Int
  clerkUserId    String @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  vendor       Vendor       @relation(fields: [vendorId], references: [id])

  @@index([organizationId])
  @@index([vendorId])
}

model Subscription {
  id               Int                @id @default(autoincrement())
  organizationId   Int
  planId           Int
  status           SubscriptionStatus @default(INACTIVE)
  stripeCustomerId String?            @unique
  stripeSubId      String?            @unique
  currentPeriodEnd DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  plan         BillingPlan  @relation(fields: [planId], references: [id])
}

model UsageEvent {
  id             Int      @id @default(autoincrement())
  organizationId Int
  vendorId       Int?
  kind           String
  details        Json?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  vendor       Vendor?      @relation(fields: [vendorId], references: [id])

  @@index([organizationId, kind, createdAt])
}

/**
 * -------------------------------------------------------
 * INVITES
 * -------------------------------------------------------
 */

model InviteToken {
  id             Int       @id @default(autoincrement())
  organizationId Int
  email          String
  role           OrgRole
  token          String    @unique
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, email])
}

/**
 * -------------------------------------------------------
 * -------------------------------------------------------
 */

model AssessmentRun {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organizationId Int
  organization   Organization @relation("OrgAssessmentRuns", fields: [organizationId], references: [id], onDelete: Cascade)

  vendorId Int?
  vendor   Vendor? @relation("VendorAssessmentRuns", fields: [vendorId], references: [id], onDelete: SetNull)

  assessmentId Int?
  assessment   Assessment? @relation("AssessmentRuns", fields: [assessmentId], references: [id], onDelete: SetNull)

  status      String    @default("IN_PROGRESS")
  startedAt   DateTime?
  completedAt DateTime?

  templateId Int?

  @@index([organizationId, id])
  @@index([organizationId, vendorId])
  @@index([organizationId, assessmentId])
  @@index([status])
}

model GovernanceReleaseManifest {
  id Int @id @default(autoincrement())

  organizationId     Int
  vendorId           Int?
  assessmentRunId    Int?
  reviewAssignmentId Int?
  reviewResponseId   Int?

  manifestVersion   String  @default("GRM-1.0")
  governanceVersion String?

  releaseState    String
  checksum        String
  packetChecksum  String?
  fundingChecksum String?

  reviewerName String?

  releasedAt  DateTime?
  confirmedAt DateTime?
  finalizedAt DateTime?

  immutableSnapshot Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([vendorId])
  @@index([reviewAssignmentId])
}

model OrganizationPlanOverride {
  id              Int       @id @default(autoincrement())
  organizationId  Int
  planTier        String
  reason          String?
  createdByUserId String?
  startsAt        DateTime  @default(now())
  expiresAt       DateTime?
  revokedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([planTier])
  @@index([startsAt])
  @@index([expiresAt])
  @@index([revokedAt])
}

enum NotificationType {
  ASSESSMENT_ASSIGNED_INTERNAL
  ASSESSMENT_ASSIGNED_TRUVERN
  REVIEW_COMPLETED
  ISSUE_ASSIGNED
  ISSUE_ESCALATED
  EVIDENCE_REQUEST_OVERDUE
  PROGRAM_STATE_SEALED
  REVIEW_STARTED
  REVIEW_RELEASED
  ASSESSMENT_SUBMITTED
  EVIDENCE_REQUEST_ASSIGNED
  VENDOR_ASSESSMENT_RECEIVED
  BOARD_PACKET_SEALED
  TRUST_NETWORK_PUBLISHED
  REVIEW_RELEASE_REQUESTED
  REVIEW_RELEASE_APPROVED
  REVIEW_RELEASE_DENIED
  VENDOR_SUBMITTED
  REVIEW_ASSIGNED
  TRUVERN_RELEASE_READY
  TRUVERN_RELEASED
  RELEASE_CONFIRMATION_REQUIRED
  REASSESSMENT_DUE
  REASSESSMENT_OVERDUE
  LOW_CREDITS
  CREDITS_GRANTED
  PLAN_OVERRIDE_APPLIED
  PLAN_OVERRIDE_EXPIRING
  GOVERNANCE_SEAL_VERIFIED
}

enum NotificationSeverity {
  INFO
  SUCCESS
  WARNING
  CRITICAL
}

model Notification {
  id             Int                  @id @default(autoincrement())
  userId         String?
  organizationId Int?
  type           NotificationType
  severity       NotificationSeverity @default(INFO)
  title          String
  message        String?
  href           String?
  metadataJson   Json?
  readAt         DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([userId])
  @@index([organizationId])
  @@index([type])
  @@index([severity])
  @@index([readAt])
  @@index([createdAt])
}

enum TruvernFrameworkStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum TruvernControlRequirementLevel {
  LOW
  MODERATE
  HIGH
  BASELINE
  CUSTOM
}

enum TruvernAssessmentLifecycleStatus {
  DRAFT
  SENT_TO_VENDOR
  VENDOR_IN_PROGRESS
  SUBMITTED
  IN_REVIEW
  REMEDIATION_REQUESTED
  ATTESTATION_REQUESTED
  READY_FOR_RELEASE
  RELEASED
  CANCELLED
}

enum TruvernFindingSeverity {
  INFO
  LOW
  MODERATE
  HIGH
  CRITICAL
}

enum TruvernFindingStatus {
  OPEN
  REMEDIATION_REQUESTED
  REMEDIATED
  ACCEPTED_RISK
  FALSE_POSITIVE
  CLOSED
}

enum TruvernRemediationStatus {
  REQUESTED
  IN_PROGRESS
  SUBMITTED
  ACCEPTED
  REJECTED
  WAIVED
}

enum TruvernAttestationStatus {
  REQUESTED
  SUBMITTED
  ACCEPTED
  REJECTED
  EXPIRED
}

model TruvernFramework {
  id          Int                    @id @default(autoincrement())
  slug        String                 @unique
  name        String
  description String?                @db.Text
  version     String?
  status      TruvernFrameworkStatus @default(DRAFT)
  metadata    Json?
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  controls    TruvernControl[]
  assessments TruvernFrameworkAssessment[]

  @@index([status])
  @@index([slug])
}

model TruvernControl {
  id               Int                             @id @default(autoincrement())
  frameworkId      Int
  controlId        String
  family           String?
  title            String
  description      String?                         @db.Text
  discussion       String?                         @db.Text
  guidance         String?                         @db.Text
  requirementLevel TruvernControlRequirementLevel?
  baselineLow      Boolean                         @default(false)
  baselineModerate Boolean                         @default(false)
  baselineHigh     Boolean                         @default(false)
  sortOrder        Int                             @default(0)
  metadata         Json?
  createdAt        DateTime                        @default(now())
  updatedAt        DateTime                        @updatedAt

  framework TruvernFramework           @relation(fields: [frameworkId], references: [id], onDelete: Cascade)
  questions TruvernControlQuestion[]
  findings  TruvernAssessmentFinding[]

  @@unique([frameworkId, controlId])
  @@index([frameworkId])
  @@index([family])
  @@index([controlId])
}

model TruvernControlQuestion {
  id                  Int      @id @default(autoincrement())
  controlId           Int
  prompt              String   @db.Text
  helpText            String?  @db.Text
  evidencePrompt      String?  @db.Text
  weight              Int      @default(1)
  requiresEvidence    Boolean  @default(false)
  requiresAttestation Boolean  @default(false)
  sortOrder           Int      @default(0)
  metadata            Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  control   TruvernControl              @relation(fields: [controlId], references: [id], onDelete: Cascade)
  responses TruvernAssessmentResponse[]

  @@index([controlId])
}

model TruvernFrameworkAssessment {
  id                 Int                              @id @default(autoincrement())
  frameworkId        Int
  organizationId     Int?
  vendorId           Int?
  assessmentRunId    Int?
  reviewAssignmentId Int?
  title              String
  status             TruvernAssessmentLifecycleStatus @default(DRAFT)
  score              Int?
  maxScore           Int?
  riskLevel          String?
  sentAt             DateTime?
  submittedAt        DateTime?
  remediationDueAt   DateTime?
  readyForReleaseAt  DateTime?
  releasedAt         DateTime?
  metadata           Json?
  createdAt          DateTime                         @default(now())
  updatedAt          DateTime                         @updatedAt

  framework    TruvernFramework               @relation(fields: [frameworkId], references: [id], onDelete: Restrict)
  responses    TruvernAssessmentResponse[]
  findings     TruvernAssessmentFinding[]
  attestations TruvernAssessmentAttestation[]

  @@index([frameworkId])
  @@index([organizationId])
  @@index([vendorId])
  @@index([assessmentRunId])
  @@index([reviewAssignmentId])
  @@index([status])
}

model TruvernAssessmentResponse {
  id            Int      @id @default(autoincrement())
  assessmentId  Int
  questionId    Int
  answer        Json?
  score         Int?
  reviewerNotes String?  @db.Text
  vendorNotes   String?  @db.Text
  evidence      Json?
  metadata      Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  assessment TruvernFrameworkAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  question   TruvernControlQuestion     @relation(fields: [questionId], references: [id], onDelete: Restrict)

  @@unique([assessmentId, questionId])
  @@index([assessmentId])
  @@index([questionId])
}

model TruvernAssessmentFinding {
  id                  Int                    @id @default(autoincrement())
  assessmentId        Int
  controlId           Int?
  severity            TruvernFindingSeverity
  status              TruvernFindingStatus   @default(OPEN)
  title               String
  description         String                 @db.Text
  recommendation      String?                @db.Text
  evidenceSummary     String?                @db.Text
  remediationRequired Boolean                @default(false)
  attestationRequired Boolean                @default(false)
  dueAt               DateTime?
  metadata            Json?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  assessment   TruvernFrameworkAssessment  @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  control      TruvernControl?             @relation(fields: [controlId], references: [id], onDelete: SetNull)
  remediations TruvernRemediationRequest[]

  @@index([assessmentId])
  @@index([controlId])
  @@index([severity])
  @@index([status])
}

model TruvernRemediationRequest {
  id               Int                      @id @default(autoincrement())
  findingId        Int
  status           TruvernRemediationStatus @default(REQUESTED)
  requestText      String                   @db.Text
  vendorResponse   String?                  @db.Text
  reviewerDecision String?                  @db.Text
  dueAt            DateTime?
  submittedAt      DateTime?
  resolvedAt       DateTime?
  metadata         Json?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt

  finding TruvernAssessmentFinding @relation(fields: [findingId], references: [id], onDelete: Cascade)

  @@index([findingId])
  @@index([status])
}

model TruvernAssessmentAttestation {
  id           Int                      @id @default(autoincrement())
  assessmentId Int
  title        String
  description  String?                  @db.Text
  requestedBy  String?
  submittedBy  String?
  status       TruvernAttestationStatus @default(REQUESTED)
  evidence     Json?
  expiresAt    DateTime?
  submittedAt  DateTime?
  reviewedAt   DateTime?
  metadata     Json?
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt

  assessment TruvernFrameworkAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@index([assessmentId])
  @@index([status])
}

model VendorGovernanceMemory {
  id                           Int      @id @default(autoincrement())
  vendorId                     Int
  reviewAssignmentId           Int?
  governanceScore              Int?
  governanceDecision           String?
  residualRisk                 String?
  criticalFailures             Int      @default(0)
  partialControls              Int      @default(0)
  missingEvidenceCount         Int      @default(0)
  remediationCount             Int      @default(0)
  breachDisclosureDetected     Boolean  @default(false)
  federalInvestigationDetected Boolean  @default(false)
  governanceNarrative          String?
  reviewerConditions           Json?
  attestationRequests          Json?
  releaseConditions            Json?
  createdAt                    DateTime @default(now())

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId, createdAt])
  @@index([reviewAssignmentId])
}

model ReviewRequest {
  id             Int       @id @default(autoincrement())
  organizationId Int?
  vendorId       Int?
