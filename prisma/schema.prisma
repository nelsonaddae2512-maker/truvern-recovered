  RemediationTask       RemediationTask?        @relation(fields: [taskId], references: [id], onUpdate: NoAction)
  WorkflowInstance      WorkflowInstance?       @relation(fields: [workflowId], references: [id], onUpdate: NoAction)

  @@index([packageId, createdAt], map: "idx_remediation_message_package")
}

model GovernanceTransparencyCheckpoint {
