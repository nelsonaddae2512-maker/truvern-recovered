model WorkflowInstance {
  id                    Int                     @id @default(autoincrement())
  organizationId        Int
  vendorId              Int?
  assessmentId          Int?
  reviewAssignmentId    Int?
  type                  String                  @default("VENDOR_GOVERNANCE_REVIEW")
  status                String                  @default("ACTIVE")
  priority              String                  @default("NORMAL")
  currentStage          String                  @default("ASSESSMENT_REVIEW")
  slaDueAt              DateTime?               @db.Timestamp(6)
  payload               Json                    @default("{}")
  createdAt             DateTime                @default(now()) @db.Timestamp(6)
  updatedAt             DateTime                @default(now()) @db.Timestamp(6)
  RemediationActivity   RemediationActivity[]
  RemediationApproval   RemediationApproval[]
  RemediationAttachment RemediationAttachment[]
  RemediationMessage    RemediationMessage[]
  RemediationTask       RemediationTask[]
  WorkflowEvent         WorkflowEvent[]
  WorkflowQueueItem     WorkflowQueueItem[]
  WorkflowTask          WorkflowTask[]

  @@index([reviewAssignmentId], map: "idx_workflow_instance_assignment")
  @@index([organizationId, status, updatedAt], map: "idx_workflow_instance_org_status")
}

model WorkflowQueueItem {
  id                 Int               @id @default(autoincrement())
  workflowId         Int?
  organizationId     Int
  vendorId           Int?
  assessmentId       Int?
  reviewAssignmentId Int?
  queue              String
  status             String            @default("OPEN")
  priority           Int               @default(50)
  assignedTo         String?
  availableAt        DateTime          @default(now()) @db.Timestamp(6)
  dueAt              DateTime?         @db.Timestamp(6)
  payload            Json              @default("{}")
  createdAt          DateTime          @default(now()) @db.Timestamp(6)
  updatedAt          DateTime          @default(now()) @db.Timestamp(6)
  WorkflowInstance   WorkflowInstance? @relation(fields: [workflowId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  WorkflowTask       WorkflowTask[]

  @@index([reviewAssignmentId, status], map: "idx_workflow_queue_assignment")
  @@index([queue, status, priority(sort: Desc), dueAt, availableAt], map: "idx_workflow_queue_open")
}

model WorkflowTask {
  id                   Int                 @id @default(autoincrement())
  workflowId           Int?
  queueItemId          Int?
  packageId            Int?
  reviewAssignmentId   Int?
  vendorId             Int?
  organizationId       Int
  type                 String
  title                String
  description          String?
  status               String              @default("OPEN")
  priority             Int                 @default(50)
  assignedTo           String?
  assignedReviewerName String?
  slaDueAt             DateTime?           @db.Timestamp(6)
  startedAt            DateTime?           @db.Timestamp(6)
  completedAt          DateTime?           @db.Timestamp(6)
  estimatedMinutes     Int?
  result               String?
  notes                String?
  payload              Json                @default("{}")
  createdAt            DateTime            @default(now()) @db.Timestamp(6)
  updatedAt            DateTime            @default(now()) @db.Timestamp(6)
  RemediationPackage   RemediationPackage? @relation(fields: [packageId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  WorkflowQueueItem    WorkflowQueueItem?  @relation(fields: [queueItemId], references: [id], onUpdate: NoAction)
  WorkflowInstance     WorkflowInstance?   @relation(fields: [workflowId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([assignedTo, status], map: "idx_workflow_task_assignee")
  @@index([packageId, status], map: "idx_workflow_task_package")
  @@index([status, priority(sort: Desc), slaDueAt, updatedAt], map: "idx_workflow_task_queue")
  @@index([workflowId, status], map: "idx_workflow_task_workflow")
}

model WorkflowEvent {
  id                 Int               @id @default(autoincrement())
  workflowId         Int?
  organizationId     Int
  vendorId           Int?
  assessmentId       Int?
  reviewAssignmentId Int?
  type               String
  actor              String?
  summary            String
  payload            Json              @default("{}")
  createdAt          DateTime          @default(now()) @db.Timestamp(6)
  WorkflowInstance   WorkflowInstance? @relation(fields: [workflowId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([workflowId, createdAt], map: "idx_workflow_event_workflow")
}

model RemediationPackage {
  id                    Int                     @id @default(autoincrement())
  reviewAssignmentId    Int
  vendorId              Int
  organizationId        Int
  evidenceRequestId     Int?
  sourceKey             String
  title                 String
  status                String                  @default("REQUESTED")
  severity              String?
  dueAt                 DateTime?               @db.Timestamp(6)
  payload               Json                    @default("{}")
  createdAt             DateTime                @default(now()) @db.Timestamp(6)
  updatedAt             DateTime                @default(now()) @db.Timestamp(6)
  RemediationActivity   RemediationActivity[]
  RemediationApproval   RemediationApproval[]
  RemediationAttachment RemediationAttachment[]
  RemediationMessage    RemediationMessage[]
  RemediationTask       RemediationTask[]
  WorkflowTask          WorkflowTask[]

  @@unique([reviewAssignmentId, sourceKey], map: "RemediationPackage_assignment_source_unique")
  @@index([vendorId, status], map: "RemediationPackage_vendor_status_idx")
}

model RemediationTask {
  id                    Int                     @id @default(autoincrement())
  packageId             Int
  workflowId            Int?
  reviewAssignmentId    Int
  vendorId              Int
  organizationId        Int
  title                 String
  description           String?
  kind                  String                  @default("EVIDENCE")
  status                String                  @default("WAITING_FOR_VENDOR")
  priority              String                  @default("NORMAL")
  dueAt                 DateTime?               @db.Timestamp(6)
  completedAt           DateTime?               @db.Timestamp(6)
  payload               Json                    @default("{}")
  createdAt             DateTime                @default(now()) @db.Timestamp(6)
  updatedAt             DateTime                @default(now()) @db.Timestamp(6)
  RemediationActivity   RemediationActivity[]
  RemediationApproval   RemediationApproval[]
  RemediationAttachment RemediationAttachment[]
  RemediationMessage    RemediationMessage[]
  RemediationPackage    RemediationPackage      @relation(fields: [packageId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  WorkflowInstance      WorkflowInstance?       @relation(fields: [workflowId], references: [id], onUpdate: NoAction)

  @@index([packageId, status], map: "idx_remediation_task_package_status")
  @@index([status, priority, dueAt, updatedAt], map: "idx_remediation_task_queue")
}

model RemediationActivity {
  id                 Int                @id @default(autoincrement())
  packageId          Int
  taskId             Int?
  workflowId         Int?
  reviewAssignmentId Int
  vendorId           Int
  organizationId     Int
  type               String
  summary            String
  actor              String?
  payload            Json               @default("{}")
  createdAt          DateTime           @default(now()) @db.Timestamp(6)
  RemediationPackage RemediationPackage @relation(fields: [packageId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  RemediationTask    RemediationTask?   @relation(fields: [taskId], references: [id], onUpdate: NoAction)
  WorkflowInstance   WorkflowInstance?  @relation(fields: [workflowId], references: [id], onUpdate: NoAction)

  @@index([packageId, createdAt], map: "idx_remediation_activity_package")
}

model RemediationApproval {
  id                 Int                @id @default(autoincrement())
